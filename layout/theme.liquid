<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#0a0a0c">

  <title>
    {%- if template == 'index' -%}
      {{ shop.name }} &mdash; Meril Medical Devices Telangana
    {%- elsif template == 'product' -%}
      {{ product.title }} &mdash; {{ shop.name }}
    {%- elsif template == 'collection' -%}
      {{ collection.title }} &mdash; {{ shop.name }}
    {%- elsif template == 'page' -%}
      {{ page.title }} &mdash; {{ shop.name }}
    {%- else -%}
      {{ page_title }} &mdash; {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  {{ content_for_header }}

  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body class="template-{{ template | replace: '.', '-' | replace: '/', '-' }}{% if customer %} customer-logged-in{% endif %}">

  <a class="skip-link" href="#main-content">Skip to content</a>

  {% section 'header' %}

  {% render 'cart-drawer' %}
  {% render 'search-drawer' %}

  <div id="modal-overlay" class="modal-overlay"></div>

  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {{ 'theme.js' | asset_url | script_tag }}
  {{ 'cart.js' | asset_url | script_tag }}
  {{ 'search.js' | asset_url | script_tag }}

  <script>
    document.documentElement.classList.remove('no-js');
  </script>
</body>
</html>