<style>
.search-page { background:#050d1a; min-height:60vh; padding:60px 20px; }
.search-inner { max-width:1100px; margin:0 auto; }
.search-title { font-size:32px; font-weight:900; color:#fff; margin-bottom:30px; }
.search-form { display:flex; gap:10px; margin-bottom:40px; }
.search-form input { flex:1; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:#fff; padding:13px 18px; border-radius:4px; font-size:15px; }
.search-form button { background:#00A651; color:#fff; border:none; padding:13px 28px; border-radius:4px; font-weight:700; cursor:pointer; font-size:15px; }
.search-results { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:20px; }
.result-card { background:#080f1e; border:1px solid rgba(255,255,255,0.07); border-radius:8px; overflow:hidden; transition:all 0.3s; }
.result-card:hover { border-color:rgba(0,166,81,0.3); transform:translateY(-3px); }
.result-card img { width:100%; height:180px; object-fit:cover; }
.result-card-body { padding:16px; }
.result-title { color:#fff; font-weight:600; font-size:14px; margin-bottom:8px; text-decoration:none; display:block; }
.result-price { color:#00A651; font-weight:700; }
.no-results { color:rgba(255,255,255,0.5); font-size:16px; }
</style>

<div class="search-page">
  <div class="search-inner">
    <h1 class="search-title">
      {% if search.performed %}
        Results for "{{ search.terms }}"
        <span style="font-size:18px;color:rgba(255,255,255,0.4);font-weight:400"> — {{ search.results_count }} found</span>
      {% else %}
        Search
      {% endif %}
    </h1>
    {% form "search" %}
      <div class="search-form">
        <input type="search" name="q" value="{{ search.terms }}" placeholder="Search products, devices...">
        <button type="submit">Search</button>
      </div>
    {% endform %}
    {% if search.performed %}
      {% if search.results_count == 0 %}
        <p class="no-results">No results found. Try a different search term.</p>
      {% else %}
        <div class="search-results">
          {% for item in search.results %}
            <div class="result-card">
              {% if item.featured_image %}
                <img src="{{ item.featured_image | img_url: 'medium' }}" alt="{{ item.title }}">
              {% endif %}
              <div class="result-card-body">
                <a href="{{ item.url }}" class="result-title">{{ item.title }}</a>
                {% if item.price %}<div class="result-price">{{ item.price | money }}</div>{% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>
