<style>
.cart-page { max-width: 1100px; margin: 60px auto; padding: 0 20px; display: grid; grid-template-columns: 1.6fr 1fr; gap: 40px; }
.cart-title { font-size: 32px; font-weight: 900; color: #fff; margin-bottom: 30px; letter-spacing: -1px; }
.cart-empty { text-align: center; padding: 80px 20px; background: #080f1e; border-radius: 10px; }
.cart-empty h2 { color: #fff; font-size: 24px; margin-bottom: 12px; }
.cart-empty p { color: rgba(255,255,255,0.5); margin-bottom: 28px; }
.btn-shop { display: inline-block; background: #00A651; color: #fff; padding: 13px 32px; border-radius: 4px; font-weight: 700; text-decoration: none; }
.cart-table { width: 100%; border-collapse: collapse; }
.cart-table th { text-align: left; font-size: 11px; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 1.5px; padding: 0 0 16px; border-bottom: 1px solid rgba(255,255,255,0.07); }
.cart-item { border-bottom: 1px solid rgba(255,255,255,0.06); }
.cart-item td { padding: 20px 0; vertical-align: middle; }
.item-img { width: 70px; height: 70px; object-fit: cover; border-radius: 6px; background: #0d1a2e; }
.item-info { padding-left: 16px; }
.item-name { color: #fff; font-weight: 600; font-size: 15px; text-decoration: none; display: block; margin-bottom: 4px; }
.item-variant { color: rgba(255,255,255,0.4); font-size: 12px; }
.item-price { color: #00A651; font-weight: 700; font-size: 16px; }
.qty-input { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; width: 60px; text-align: center; padding: 8px; border-radius: 4px; font-size: 15px; }
.remove-btn { background: none; border: none; color: rgba(255,255,255,0.3); cursor: pointer; font-size: 18px; transition: color 0.2s; }
.remove-btn:hover { color: #ff4444; }
.cart-summary { background: #080f1e; border: 1px solid rgba(255,255,255,0.07); border-radius: 10px; padding: 32px; position: sticky; top: 90px; height: fit-content; }
.summary-title { font-size: 18px; font-weight: 700; color: #fff; margin-bottom: 24px; }
.summary-row { display: flex; justify-content: space-between; margin-bottom: 14px; font-size: 14px; color: rgba(255,255,255,0.6); }
.summary-total { display: flex; justify-content: space-between; margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.08); font-size: 18px; font-weight: 700; color: #fff; }
.summary-note { font-size: 12px; color: rgba(255,255,255,0.35); margin: 16px 0; line-height: 1.6; }
.btn-checkout { display: block; width: 100%; background: #00A651; color: #fff; text-align: center; padding: 15px; border-radius: 4px; font-weight: 700; font-size: 16px; text-decoration: none; border: none; cursor: pointer; transition: background 0.2s; margin-bottom: 10px; }
.btn-checkout:hover { background: #008c44; }
.btn-continue { display: block; width: 100%; background: transparent; color: rgba(255,255,255,0.5); text-align: center; padding: 12px; border-radius: 4px; font-size: 14px; text-decoration: none; border: 1px solid rgba(255,255,255,0.1); transition: all 0.2s; }
.btn-continue:hover { color: #fff; border-color: rgba(255,255,255,0.3); }
.page-bg { background: #050d1a; min-height: 80vh; padding: 40px 0; }
@media(max-width:768px) { .cart-page { grid-template-columns: 1fr; } }
</style>

<div class="page-bg">
  {% if cart.item_count == 0 %}
    <div style="max-width:1100px;margin:0 auto;padding:0 20px">
      <h1 class="cart-title">Your Cart</h1>
      <div class="cart-empty">
        <h2>Your cart is empty</h2>
        <p>Add orthopedic implants, instruments or diagnostics from our catalog.</p>
        <a href="/collections/all" class="btn-shop">Browse Catalog</a>
      </div>
    </div>
  {% else %}
    <div class="cart-page">
      <div>
        <h1 class="cart-title">Your Cart ({{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }})</h1>
        {% form "cart", cart %}
          <table class="cart-table">
            <thead>
              <tr>
                <th colspan="2">Product</th>
                <th>Price</th>
                <th>Qty</th>
                <th>Total</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {% for item in cart.items %}
              <tr class="cart-item">
                <td style="width:70px">
                  {% if item.image %}
                    <img class="item-img" src="{{ item.image | img_url: 'small' }}" alt="{{ item.title }}">
                  {% else %}
                    <div class="item-img" style="display:flex;align-items:center;justify-content:center;font-size:24px">🦴</div>
                  {% endif %}
                </td>
                <td>
                  <div class="item-info">
                    <a href="{{ item.url }}" class="item-name">{{ item.product.title }}</a>
                    {% unless item.variant.title == 'Default Title' %}
                      <span class="item-variant">{{ item.variant.title }}</span>
                    {% endunless %}
                  </div>
                </td>
                <td class="item-price">{{ item.price | money }}</td>
                <td>
                  <input class="qty-input" type="number" name="updates[]" value="{{ item.quantity }}" min="1">
                </td>
                <td class="item-price">{{ item.line_price | money }}</td>
                <td>
                  <button class="remove-btn" type="submit" name="updates[]" value="0">✕</button>
                </td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
          <div style="margin-top:20px;display:flex;gap:12px;flex-wrap:wrap">
            <button type="submit" style="background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.6);border:1px solid rgba(255,255,255,0.1);padding:10px 22px;border-radius:4px;cursor:pointer;font-size:14px">Update Cart</button>
          </div>
        {% endform %}
      </div>
      <div>
        <div class="cart-summary">
          <div class="summary-title">Order Summary</div>
          <div class="summary-row"><span>Subtotal</span><span>{{ cart.total_price | money }}</span></div>
          <div class="summary-row"><span>Shipping</span><span style="color:#00A651">Calculated at checkout</span></div>
          <div class="summary-total"><span>Total</span><span>{{ cart.total_price | money }}</span></div>
          <p class="summary-note">GST and shipping calculated at checkout. For bulk/hospital orders contact us directly.</p>
          <a href="/checkout" class="btn-checkout">Proceed to Checkout →</a>
          <a href="/collections/all" class="btn-continue">Continue Shopping</a>
        </div>
      </div>
    </div>
  {% endif %}
</div>
