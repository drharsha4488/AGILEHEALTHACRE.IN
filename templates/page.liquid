<style>
.page-wrapper { background: #050d1a; min-height: 60vh; }
.page-hero { background: linear-gradient(135deg, #0d1b3e, #050d1a); padding: 60px 20px; border-bottom: 1px solid rgba(255,255,255,0.06); }
.page-hero-inner { max-width: 1100px; margin: 0 auto; }
.page-hero h1 { font-size: 38px; font-weight: 900; color: #fff; letter-spacing: -1px; }
.page-hero p { color: rgba(255,255,255,0.5); margin-top: 8px; font-size: 15px; }
.page-body { max-width: 1100px; margin: 0 auto; padding: 60px 20px; color: rgba(255,255,255,0.75); font-size: 15px; line-height: 1.9; }
.page-body h2, .page-body h3 { color: #fff; margin: 28px 0 12px; font-weight: 700; }
.page-body a { color: #00A651; }
</style>

<div class="page-wrapper">
  <div class="page-hero">
    <div class="page-hero-inner">
      <h1>{{ page.title }}</h1>
    </div>
  </div>
  <div class="page-body">
    {{ page.content }}
  </div>
</div>
