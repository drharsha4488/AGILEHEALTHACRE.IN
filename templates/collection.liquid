<style>
.collection-page { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }
.collection-header { text-align: center; margin-bottom: 40px; }
.collection-title { font-size: 36px; font-weight: 800; color: #1a1a2e; }
.products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 25px; }
.product-card { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 3px 15px rgba(0,0,0,0.07); transition: all 0.3s; }
.product-card:hover { transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0,87,168,0.12); }
.product-card img { width: 100%; height: 220px; object-fit: cover; }
.card-body { padding: 20px; }
.card-title { font-size: 16px; font-weight: 600; color: #1a1a2e; margin-bottom: 8px; }
.card-price { color: #0057A8; font-weight: 700; font-size: 18px; }
.card-link { display: block; margin-top: 12px; text-align: center; background: #0057A8; color: #fff; padding: 10px; border-radius: 8px; text-decoration: none; font-weight: 600; transition: background 0.3s; }
.card-link:hover { background: #003d7a; }
</style>

<div class="collection-page">
  <div class="collection-header">
    <h1 class="collection-title">{{ collection.title }}</h1>
  </div>
  <div class="products-grid">
    {% for product in collection.products %}
    <div class="product-card">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | img_url: "medium" }}" alt="{{ product.title }}">
      {% endif %}
      <div class="card-body">
        <div class="card-title">{{ product.title }}</div>
        <div class="card-price">{{ product.price | money }}</div>
        <a href="{{ product.url }}" class="card-link">View Details</a>
      </div>
    </div>
    {% endfor %}
  </div>
</div>