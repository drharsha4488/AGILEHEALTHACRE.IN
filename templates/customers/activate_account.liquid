<div style="min-height:80vh;display:flex;align-items:center;justify-content:center;padding:40px 24px;">
  <div style="max-width:440px;width:100%;">
    <h1 style="color:#fff;font-size:24px;font-weight:700;margin-bottom:8px;">Activate Account</h1>
    <p style="color:#8899aa;margin-bottom:28px;font-size:14px;">Create a password to activate your account.</p>
    {%- form 'activate_customer_password' -%}
      {%- if form.errors -%}
        <div style="background:rgba(255,68,68,0.1);border:1px solid #ff4444;border-radius:8px;padding:12px;color:#ff4444;font-size:14px;margin-bottom:16px;">{{ form.errors | default_errors }}</div>
      {%- endif -%}
      <div class="form-group">
        <label style="display:block;color:#8899aa;font-size:13px;margin-bottom:6px;">Password</label>
        <input type="password" name="customer[password]" required placeholder="Create a password" style="width:100%;background:#050d1a;border:1px solid #1a2a40;color:#fff;padding:11px 14px;border-radius:8px;font-size:14px;box-sizing:border-box;">
      </div>
      <div class="form-group">
        <label style="display:block;color:#8899aa;font-size:13px;margin-bottom:6px;">Confirm Password</label>
        <input type="password" name="customer[password_confirmation]" required placeholder="Confirm your password" style="width:100%;background:#050d1a;border:1px solid #1a2a40;color:#fff;padding:11px 14px;border-radius:8px;font-size:14px;box-sizing:border-box;">
      </div>
      <button type="submit" class="btn btn-primary" style="display:block;width:100%;margin-top:16px;">Activate Account</button>
    {%- endform -%}
  </div>
</div>
