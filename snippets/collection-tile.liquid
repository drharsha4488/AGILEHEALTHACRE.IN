{%- comment -%}Collection tile card — used in list-collections{%- endcomment -%}
{%- assign coll = collection -%}
<a href="{{ coll.url }}" class="collection-tile">
  <div class="collection-tile__img">
    {%- if coll.image -%}
      <img src="{{ coll.image | image_url: width: 400 }}" alt="{{ coll.title | escape }}" loading="lazy" width="400" height="300">
    {%- else -%}
      <div class="collection-tile__placeholder">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".4"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 9h18M9 21V9"/></svg>
      </div>
    {%- endif -%}
    <div class="collection-tile__badge">{{ coll.products_count }} products</div>
  </div>
  <div class="collection-tile__info">
    <h3 class="collection-tile__title">{{ coll.title }}</h3>
    {%- if coll.description != blank -%}
      <p class="collection-tile__desc">{{ coll.description | strip_html | truncate: 80 }}</p>
    {%- endif -%}
    <span class="collection-tile__cta">Browse <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
  </div>
</a>
<style>
.collection-tile{display:flex;flex-direction:column;background:var(--surface,#13141a);border:1px solid var(--border,rgba(255,255,255,0.08));border-radius:14px;overflow:hidden;text-decoration:none;transition:border-color .2s,transform .2s;color:inherit}
.collection-tile:hover{border-color:var(--green,#00D964);transform:translateY(-4px)}
.collection-tile__img{position:relative;aspect-ratio:4/3;overflow:hidden;background:var(--elevated,#1c1d24)}
.collection-tile__img img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.collection-tile:hover .collection-tile__img img{transform:scale(1.05)}
.collection-tile__placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--text-2,#a1a1aa)}
.collection-tile__badge{position:absolute;bottom:10px;left:10px;background:rgba(0,0,0,0.7);color:#fff;font-size:11px;padding:4px 10px;border-radius:20px;backdrop-filter:blur(8px)}
.collection-tile__info{padding:16px}
.collection-tile__title{font-size:16px;font-weight:600;margin:0 0 6px;color:var(--text,#fff)}
.collection-tile__desc{font-size:13px;color:var(--text-2,#a1a1aa);margin:0 0 12px;line-height:1.5}
.collection-tile__cta{display:inline-flex;align-items:center;gap:4px;font-size:13px;font-weight:500;color:var(--green,#00D964)}
</style>