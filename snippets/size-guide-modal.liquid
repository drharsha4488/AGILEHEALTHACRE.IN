{%- comment -%}Size reference guide modal{%- endcomment -%}
<div class="modal-overlay" id="size-guide" data-modal="size-guide" role="dialog" aria-modal="true" aria-label="Size Guide">
  <div class="modal-card">
    <button type="button" class="modal-close" aria-label="Close size guide" data-close-modal>✕</button>
    <h2 style="font-size:28px;margin-bottom:8px">Size Reference Guide</h2>
    <p class="text-mute" style="margin-bottom:16px">Clinical sizing chart. For custom or implant-specific sizing, please contact our clinical team.</p>

    <table class="size-guide-table">
      <thead>
        <tr><th>Size</th><th>Diameter (mm)</th><th>Length (mm)</th><th>Typical Use</th></tr>
      </thead>
      <tbody>
        <tr><td>XS</td><td>3.5</td><td>10 – 30</td><td>Pediatric / Hand</td></tr>
        <tr><td>S</td><td>4.0</td><td>20 – 50</td><td>Forearm / Distal</td></tr>
        <tr><td>M</td><td>4.5</td><td>30 – 80</td><td>Tibia / Humerus</td></tr>
        <tr><td>L</td><td>5.0</td><td>50 – 120</td><td>Femoral shaft</td></tr>
        <tr><td>XL</td><td>6.5</td><td>80 – 180</td><td>Long-bone / Custom</td></tr>
      </tbody>
    </table>

    <p class="text-mute mt-6" style="font-size:12px">Sizing is indicative. Always confirm with manufacturer IFU and intra-operative measurement.</p>
    <div style="margin-top:20px;display:flex;gap:8px;justify-content:flex-end">
      <button class="btn btn-secondary" data-close-modal>Close</button>
      <a href="/pages/contact" class="btn btn-primary">Talk to a clinical specialist</a>
    </div>
  </div>
</div>
