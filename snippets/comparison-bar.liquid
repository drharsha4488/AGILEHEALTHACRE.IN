{%- comment -%}Comparison bar (floating){%- endcomment -%}
<div class="comparison-bar" id="comparison-bar" style="display:none">
  <div class="container" style="display:flex;align-items:center;gap:16px;padding:14px 24px">
    <div style="font-weight:600">Compare (<span id="compare-count">0</span>)</div>
    <div id="compare-thumbs" style="display:flex;gap:6px"></div>
    <div style="margin-left:auto;display:flex;gap:8px">
      <button class="btn btn-secondary btn-sm" id="compare-clear">Clear</button>
      <button class="btn btn-primary btn-sm" id="compare-now">Compare Now</button>
    </div>
  </div>
</div>
<div class="modal-overlay" id="compare-modal" data-modal="compare-modal" role="dialog" aria-modal="true">
  <div class="modal-card" style="max-width:1100px">
    <button type="button" class="modal-close" aria-label="Close" data-close-modal>✕</button>
    <h2>Product Comparison</h2>
    <div id="compare-table"></div>
  </div>
</div>
