{%- comment -%}
  Sticky bottom cart bar. Accepts: product, variant
{%- endcomment -%}
{%- assign variant = variant | default: product.selected_or_first_available_variant -%}

<div class="sticky-cart-bar" id="sticky-cart-bar" data-sticky-target>
  <div class="left">
    <div class="img">
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 120 }}" alt="{{ product.title | escape }}" loading="lazy" width="54" height="54">
      {%- endif -%}
    </div>
    <div class="info">
      <div class="title">{{ product.title | escape }}</div>
      <div class="price">{{ variant.price | money }}</div>
    </div>
  </div>
  <div class="right">
    <div class="qty-control" style="display:none">
      <button type="button" data-qty-dec aria-label="Decrease">−</button>
      <input type="number" value="1" min="1" data-sticky-qty>
      <button type="button" data-qty-inc aria-label="Increase">+</button>
    </div>
    {%- if product.tags contains 'quote-only' -%}
      <a href="/pages/quote?product={{ product.handle }}" class="btn btn-blue">Request Quote</a>
    {%- else -%}
      <button type="button" class="btn btn-primary" data-sticky-add {% if variant.available == false %}disabled{% endif %}>
        {%- if variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
      </button>
    {%- endif -%}
  </div>
</div>
