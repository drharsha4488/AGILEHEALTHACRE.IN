{%- comment -%}Wishlist toggle button. Accepts: product{%- endcomment -%}
<button type="button" class="wishlist-btn" data-wishlist data-product-id="{{ product.id }}" aria-label="Add to wishlist">
  <svg class="heart" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
  </svg>
  <span class="label">Save</span>
</button>
