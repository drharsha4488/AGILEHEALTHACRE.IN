<div id="search-drawer" class="drawer search-drawer">
  <div class="drawer-header">
    <h3 class="drawer-title">Search Products</h3>
    <button class="drawer-close" data-drawer-close aria-label="Close">&times;</button>
  </div>
  <div class="drawer-body" style="padding:20px">
    <form action="/search" method="get" role="search">
      <input type="hidden" name="type" value="product">
      <div style="position:relative;margin-bottom:20px">
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#666;pointer-events:none" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="search" name="q" id="search-input" placeholder="Search devices, brands..." autocomplete="off"
          style="width:100%;background:var(--elevated,#1c1d24);border:1px solid var(--border,rgba(255,255,255,0.1));color:#fff;padding:12px 12px 12px 44px;border-radius:8px;font-size:15px;box-sizing:border-box;outline:none">
      </div>
    </form>
    <div id="search-results" style="display:flex;flex-direction:column;gap:8px"></div>
  </div>
</div>

<style>
/* Search drawer — slides in from LEFT */
#search-drawer {
  left: 0;
  right: auto;
  transform: translateX(-100%);
  border-left: none;
  border-right: 1px solid var(--border, rgba(255,255,255,0.1));
  width: min(420px, 100vw);
}
#search-drawer.open { transform: translateX(0); }
#search-input:focus { border-color: var(--green, #00D964) !important; }
.sri { display:flex;gap:12px;align-items:center;padding:10px;background:var(--elevated,#1c1d24);border:1px solid var(--border,rgba(255,255,255,0.1));border-radius:8px;text-decoration:none;transition:border-color .2s }
.sri:hover { border-color:var(--green,#00D964) }
.sri-img { width:50px;height:50px;border-radius:6px;background-size:cover;background-position:center;background-color:var(--surface,#13141a);flex-shrink:0 }
.sri-info { flex:1;min-width:0 }
.sri-title { color:#fff;font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis }
.sri-price { color:var(--green,#00D964);font-size:13px;margin-top:2px }
</style>

<script>
(function(){
  var input = document.getElementById('search-input');
  var results = document.getElementById('search-results');
  if (!input || !results) return;
  var timer;
  input.addEventListener('input', function(){
    clearTimeout(timer);
    var q = this.value.trim();
    if (q.length < 2) { results.innerHTML = ''; return; }
    timer = setTimeout(function(){
      fetch('/search/suggest.json?q=' + encodeURIComponent(q) + '&resources[type]=product&resources[limit]=6')
        .then(function(r){ return r.json(); })
        .then(function(data){
          results.innerHTML = '';
          var prods = (data.resources && data.resources.results && data.resources.results.products) || [];
          if (!prods.length) {
            results.innerHTML = '<p style="color:#888;font-size:14px;padding:8px">No results found.</p>';
            return;
          }
          prods.forEach(function(p){
            var img = (p.featured_image && p.featured_image.url) ? p.featured_image.url : '';
            var price = p.price ? new Intl.NumberFormat('en-IN',{style:'currency',currency:'INR',minimumFractionDigits:0}).format(parseInt(p.price)/100) : '';
            var a = document.createElement('a');
            a.className = 'sri';
            a.href = p.url;
            a.innerHTML = '<div class="sri-img" style="background-image:url(' + img + ')"></div>'
              + '<div class="sri-info"><div class="sri-title">' + p.title + '</div>'
              + (price ? '<div class="sri-price">' + price + '</div>' : '') + '</div>';
            results.appendChild(a);
          });
        }).catch(function(){});
    }, 300);
  });
})();
</script>