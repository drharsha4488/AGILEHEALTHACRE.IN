{%- comment -%}Product card — list view. Accepts: product{%- endcomment -%}
{%- assign v = product.selected_or_first_available_variant -%}
{%- assign on_sale = false -%}
{%- if v.compare_at_price > v.price -%}{%- assign on_sale = true -%}{%- endif -%}

<div class="product-card list" data-product-card data-product-handle="{{ product.handle }}">
  <a href="{{ product.url }}" class="product-card-media" tabindex="-1">
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 400 }}"
           alt="{{ product.title | escape }}" loading="lazy" width="200" height="200">
    {%- endif -%}
  </a>

  <div class="product-card-body" style="flex:1">
    <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:16px">
      <div style="flex:1;min-width:0">
        {%- if product.vendor != blank -%}
          <div class="product-card-vendor">{{ product.vendor }}</div>
        {%- endif -%}
        <h3 style="margin:4px 0 8px;font-size:18px;font-weight:600;color:#111;letter-spacing:-0.01em">
          <a href="{{ product.url }}" style="color:inherit;text-decoration:none">{{ product.title | escape }}</a>
        </h3>
        <p style="font-size:13px;color:#555;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin:0 0 12px">
          {{ product.description | strip_html | truncate: 180 }}
        </p>

        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px">
          {%- if product.metafields.custom.regulatory_approvals -%}
            {%- for r in product.metafields.custom.regulatory_approvals -%}
              <span class="tag tag-green" style="background:rgba(0,217,100,0.08);color:#00874a;font-size:10px">{{ r }}</span>
            {%- endfor -%}
          {%- endif -%}
          {%- for opt in product.options_with_values -%}
            <span style="font-size:11px;color:#666"><strong>{{ opt.name }}:</strong> {{ opt.values | join: ', ' | truncate: 40 }}</span>
          {%- endfor -%}
        </div>

        {%- if v.inventory_management != blank -%}
          <div style="font-size:12px;color:{% if v.inventory_quantity > 0 %}#00874a{% else %}#888{% endif %};font-weight:500">
            {%- if v.inventory_quantity > 10 -%}● In Stock — Ships in 2 hours
            {%- elsif v.inventory_quantity > 0 -%}● Only {{ v.inventory_quantity }} left
            {%- else -%}○ Out of stock{%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <div style="text-align:right;flex-shrink:0;display:flex;flex-direction:column;gap:8px;align-items:flex-end">
        <div class="product-card-price">
          {%- if product.tags contains 'quote-only' -%}
            <a href="/pages/quote?product={{ product.handle }}" style="font-size:14px;color:var(--blue)">Request Quote</a>
          {%- elsif on_sale -%}
            <div style="font-size:22px;font-weight:700">{{ v.price | money }}</div>
            <div style="font-size:13px;color:#999;text-decoration:line-through">{{ v.compare_at_price | money }}</div>
          {%- else -%}
            <div style="font-size:22px;font-weight:700">{{ v.price | money }}</div>
          {%- endif -%}
        </div>
        <a href="{{ product.url }}" class="btn btn-primary btn-sm">View Details</a>
        <button type="button" class="btn btn-secondary btn-sm" data-quick-view data-handle="{{ product.handle }}">Quick View</button>
      </div>
    </div>
  </div>
</div>
