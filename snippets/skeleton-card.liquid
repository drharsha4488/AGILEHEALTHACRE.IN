{%- comment -%}Skeleton loader card{%- endcomment -%}
<div class="product-card" aria-hidden="true">
  <div class="skeleton" style="aspect-ratio:1/1;border-radius:0"></div>
  <div class="product-card-body" style="background:#fff">
    <div class="skeleton" style="height:10px;width:40%;background:#eee;animation:none"></div>
    <div class="skeleton" style="height:16px;width:90%;background:#eee;animation:none"></div>
    <div class="skeleton" style="height:16px;width:60%;background:#eee;animation:none"></div>
    <div class="skeleton" style="height:20px;width:50%;background:#eee;margin-top:8px;animation:none"></div>
  </div>
</div>
