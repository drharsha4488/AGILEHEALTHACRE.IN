{%- paginate collection.products by 24 -%}
<div class="collection-page-wrap container">
  <div class="collection-header">
    <nav class="breadcrumbs">
      <a href="/">Home</a> &rsaquo;
      <a href="/collections/all">Collections</a> &rsaquo;
      <span>{{ collection.title }}</span>
    </nav>
    <h1 class="collection-title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection-desc">{{ collection.description }}</div>
    {%- endif -%}
  </div>

  <div class="collection-toolbar">
    <span class="collection-count">{{ collection.products_count }} products</span>
    <div class="sort-wrap">
      <label for="sort-select">Sort by:</label>
      <select id="sort-select" onchange="window.location = this.value" class="sort-select">
        {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
        <option value="{{ collection.url }}?sort_by=manual" {% if sort_by == 'manual' %}selected{% endif %}>Featured</option>
        <option value="{{ collection.url }}?sort_by=price-ascending" {% if sort_by == 'price-ascending' %}selected{% endif %}>Price: Low to High</option>
        <option value="{{ collection.url }}?sort_by=price-descending" {% if sort_by == 'price-descending' %}selected{% endif %}>Price: High to Low</option>
        <option value="{{ collection.url }}?sort_by=title-ascending" {% if sort_by == 'title-ascending' %}selected{% endif %}>A–Z</option>
        <option value="{{ collection.url }}?sort_by=created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>Newest</option>
      </select>
    </div>
  </div>

  <div class="collection-grid product-grid product-grid--4">
    {%- for product in collection.products -%}
      {%- render 'product-card', product: product -%}
    {%- else -%}
      <p style="color:#8899aa;grid-column:1/-1;">No products found in this collection.</p>
    {%- endfor -%}
  </div>

  {%- render 'pagination', paginate: paginate -%}
</div>
{%- endpaginate -%}

<style>
.collection-page-wrap { padding: 32px 24px; }
.collection-header { margin-bottom: 32px; }
.breadcrumbs { font-size: 12px; color: #8899aa; margin-bottom: 16px; }
.breadcrumbs a { color: #8899aa; text-decoration: none; }
.breadcrumbs a:hover { color: #00A651; }
.collection-title { font-size: 32px; font-weight: 700; color: #fff; margin: 8px 0; }
.collection-desc { color: #8899aa; line-height: 1.6; max-width: 700px; margin-top: 8px; }
.collection-toolbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid #1a2a40; flex-wrap: wrap; gap: 12px; }
.collection-count { color: #8899aa; font-size: 14px; }
.sort-wrap { display: flex; align-items: center; gap: 10px; color: #8899aa; font-size: 14px; }
.sort-select { background: #0a1628; border: 1px solid #1a2a40; color: #fff; padding: 8px 12px; border-radius: 6px; font-size: 13px; cursor: pointer; }
</style>

{% schema %}
{"name":"Main Collection","settings":[],"presets":[{"name":"Main Collection"}]}
{% endschema %}
