{{ 'collection.css' | asset_url | stylesheet_tag }}
<script src="{{ 'collection.js' | asset_url }}" defer></script>

{% paginate collection.products by 24 %}
<section class="collection-hero" {% if collection.image %}style="background-image:linear-gradient(rgba(10,10,12,0.7),rgba(10,10,12,0.9)),url('{{ collection.image | image_url: width: 2000 }}');background-size:cover;background-position:center"{% endif %}>
  <div class="container">
    {%- render 'breadcrumbs' -%}
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p>{{ collection.description | strip_html | truncate: 220 }}</p>
    {%- endif -%}
    <div class="hero-stats">
      <span>{{ collection.all_products_count }} products</span>
      <span>·</span>
      <span>★ 4.8 avg rating</span>
      <span>·</span>
      <span>CDSCO approved</span>
    </div>
  </div>
</section>

{%- render 'collection-sub-pills', collection: collection -%}
{%- render 'active-filters-bar', collection: collection -%}

<div class="container">
  <div class="collection-layout">
    <aside class="collection-sidebar" id="collection-sidebar">
      {%- render 'collection-filters', collection: collection -%}
    </aside>

    <main class="collection-main">
      <div class="sort-bar">
        <div class="result-count">
          Showing {{ paginate.current_offset | plus: 1 }}–{{ paginate.current_offset | plus: collection.products.size }} of {{ collection.all_products_count }}
        </div>
        <div style="display:flex;gap:12px;align-items:center">
          <button class="btn btn-secondary btn-sm" id="mobile-filter-btn" style="display:none">⚙ Filters</button>
          {%- render 'view-toggle' -%}
          {%- render 'sort-dropdown' -%}
        </div>
      </div>

      {%- if collection.products.size == 0 -%}
        {%- render 'empty-state',
          title: 'No products match these filters',
          message: 'Try removing some filters or browse all categories.',
          action_text: 'Clear filters',
          action_url: collection.url -%}
      {%- else -%}
        <div class="product-grid" data-view="grid" id="product-grid">
          {%- for p in collection.products -%}
            {%- render 'product-card-grid', product: p -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- render 'pagination', paginate: paginate -%}
    </main>
  </div>
</div>

{%- if collection.metafields.custom.faq -%}
  {% section 'collection-faq' %}
{%- endif -%}

{%- if collection.metafields.custom.related_collections.value.size > 0 -%}
  <section class="related-collections" style="padding:48px 0;border-top:1px solid var(--border)">
    <div class="container">
      <div class="section-heading"><h2>Related Categories</h2></div>
      <div class="grid grid-4">
        {%- for c in collection.metafields.custom.related_collections.value limit: 8 -%}
          <a href="{{ c.url }}" class="b2b-tier-card" style="text-decoration:none">
            <div>
              <div class="tier-name">{{ c.title }}</div>
              <div class="text-mute" style="font-size:13px">{{ c.products_count }} products</div>
            </div>
            <div style="color:var(--green)">→</div>
          </a>
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{%- render 'quick-view-modal' -%}
{%- render 'comparison-bar' -%}
{% endpaginate %}

{% schema %}
{
  "name": "Main Collection",
  "tag": "section",
  "settings": [
    { "type": "select", "id": "products_per_page", "label": "Products per page",
      "options": [{"value":"24","label":"24"},{"value":"36","label":"36"},{"value":"48","label":"48"}],
      "default": "24" },
    { "type": "checkbox", "id": "enable_filters", "label": "Enable filters", "default": true },
    { "type": "checkbox", "id": "enable_compare", "label": "Enable product comparison", "default": true }
  ],
  "presets": [{ "name": "Main Collection" }]
}
{% endschema %}
