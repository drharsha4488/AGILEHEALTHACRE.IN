<div id="announcement-bar" class="announcement-bar">
  <span class="ann-text">
    {%- if section.settings.text != blank -%}
      {{ section.settings.text }}
    {%- else -%}
      ⚡ 2-Hour OT Dispatch across all 33 Telangana Districts
    {%- endif -%}
    &nbsp;|&nbsp;
    <a href="{%- if section.settings.whatsapp_link != blank -%}{{ section.settings.whatsapp_link }}{%- else -%}https://wa.me/917416521222{%- endif -%}" target="_blank" rel="noopener">📞 WhatsApp: +91 74165 21222</a>
  </span>
  <button id="ann-bar-dismiss" class="ann-dismiss" aria-label="Dismiss announcement">&times;</button>
</div>
<style>
.announcement-bar { background: #00A651; color: #fff; font-size: 13px; padding: 9px 20px; display: flex; align-items: center; justify-content: center; gap: 16px; position: relative; }
.announcement-bar a { color: #fff; font-weight: 600; text-decoration: none; }
.ann-dismiss { position: absolute; right: 16px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #fff; font-size: 20px; cursor: pointer; line-height: 1; opacity: 0.8; }
.ann-dismiss:hover { opacity: 1; }
</style>
<script>
(function(){
  if(sessionStorage.getItem('ann-bar-dismissed')) document.getElementById('announcement-bar').style.display='none';
  var btn = document.getElementById('ann-bar-dismiss');
  if(btn) btn.addEventListener('click',function(){ document.getElementById('announcement-bar').style.display='none'; sessionStorage.setItem('ann-bar-dismissed','1'); });
})();
</script>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {"type":"text","id":"text","label":"Announcement text","default":"⚡ 2-Hour OT Dispatch across all 33 Telangana Districts"},
    {"type":"url","id":"whatsapp_link","label":"WhatsApp link"}
  ],
  "presets": [{"name":"Announcement Bar"}]
}
{% endschema %}
