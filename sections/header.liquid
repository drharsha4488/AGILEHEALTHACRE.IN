<style>
:root { --green:#00A651; --bg:#050d1a; --bg2:#080f1e; --bg3:#0a1628; --border:#1a2a40; --text:#ccd6e0; --white:#fff; }
#announcement-bar { background: var(--green); color: #fff; font-size: 13px; padding: 8px 20px; display: flex; align-items: center; justify-content: center; gap: 16px; position: relative; }
#announcement-bar a { color: #fff; font-weight: 600; text-decoration: none; }
#ann-dismiss { position: absolute; right: 16px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #fff; font-size: 18px; cursor: pointer; line-height: 1; opacity: 0.8; }
#ann-dismiss:hover { opacity: 1; }
.site-header { background: var(--bg); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 500; }
.header-inner { max-width: 1280px; margin: 0 auto; padding: 0 24px; height: 64px; display: flex; align-items: center; gap: 32px; }
.site-logo { text-decoration: none; display: flex; flex-direction: column; flex-shrink: 0; }
.site-logo .logo-name { font-size: 22px; font-weight: 800; color: #fff; letter-spacing: -0.5px; line-height: 1.1; }
.site-logo .logo-name span { color: var(--green); }
.site-logo .logo-tagline { font-size: 10px; color: #8899aa; letter-spacing: 0.5px; text-transform: uppercase; }
.nav-primary { display: flex; align-items: center; gap: 4px; flex: 1; }
.nav-link { color: var(--text); text-decoration: none; font-size: 14px; font-weight: 500; padding: 8px 12px; border-radius: 6px; transition: color 0.2s; white-space: nowrap; }
.nav-link:hover { color: #fff; }
.mega-menu-parent { position: relative; }
.mega-menu-parent > .nav-link::after { content: " ▾"; font-size: 10px; }
.mega-menu { position: absolute; top: calc(100% + 8px); left: 0; background: var(--bg3); border: 1px solid var(--border); border-radius: 10px; padding: 20px; min-width: 540px; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; opacity: 0; pointer-events: none; transition: opacity 0.2s, transform 0.2s; transform: translateY(-8px); box-shadow: 0 20px 60px rgba(0,0,0,0.5); }
.mega-menu-parent:hover .mega-menu, .mega-menu-parent:focus-within .mega-menu { opacity: 1; pointer-events: all; transform: translateY(0); }
.mega-menu-col h4 { color: #8899aa; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 12px; }
.mega-menu-col a { display: block; color: var(--text); text-decoration: none; font-size: 14px; padding: 7px 10px; border-radius: 6px; transition: background 0.15s, color 0.15s; }
.mega-menu-col a:hover { background: rgba(0,166,81,0.12); color: var(--green); }
.mega-featured { background: linear-gradient(135deg, rgba(0,166,81,0.15), rgba(0,166,81,0.05)); border: 1px solid rgba(0,166,81,0.2); border-radius: 8px; padding: 16px; }
.mega-featured h4 { color: var(--green); }
.mega-stat { display: flex; gap: 8px; align-items: center; margin-bottom: 8px; font-size: 13px; color: var(--text); }
.mega-stat strong { color: #fff; }
.header-actions { display: flex; align-items: center; gap: 8px; margin-left: auto; flex-shrink: 0; }
.header-icon-btn { display: flex; align-items: center; gap: 6px; background: none; border: none; color: var(--text); cursor: pointer; padding: 8px; border-radius: 6px; text-decoration: none; font-size: 13px; transition: color 0.2s; position: relative; }
.header-icon-btn:hover { color: #fff; }
.cart-badge { background: var(--green); color: #fff; font-size: 10px; font-weight: 700; width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center; position: absolute; top: 2px; right: 2px; line-height: 1; }
.header-cta { background: var(--green); color: #fff !important; padding: 8px 16px; border-radius: 6px; font-weight: 600; }
.header-cta:hover { background: #008f44; }
#mobile-menu-toggle { display: none; background: none; border: none; color: var(--text); cursor: pointer; padding: 8px; }
#mobile-menu { display: none; background: var(--bg3); border-top: 1px solid var(--border); padding: 16px 24px; }
#mobile-menu a { display: block; color: var(--text); text-decoration: none; font-size: 15px; padding: 12px 0; border-bottom: 1px solid var(--border); }
#mobile-menu a:last-child { border-bottom: none; }
@media(max-width:1024px){
  .nav-primary { display: none; }
  #mobile-menu-toggle { display: flex; }
  #mobile-menu.is-open { display: block; }
}
@media(max-width:600px){ .header-inner { padding: 0 16px; } }
</style>

