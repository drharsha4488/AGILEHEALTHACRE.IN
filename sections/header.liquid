<script>
(function(){
  // Announcement dismiss
  var ann = document.getElementById('announcement-bar');
  var btn = document.getElementById('ann-dismiss');
  if(btn && ann){
    if(sessionStorage.getItem('ann-dismissed')){ ann.style.display='none'; }
    btn.addEventListener('click', function(){ ann.style.display='none'; sessionStorage.setItem('ann-dismissed','1'); });
  }
  // Mobile menu toggle
  var toggle = document.getElementById('mobile-menu-toggle');
  var menu = document.getElementById('mobile-menu');
  if(toggle && menu){
    toggle.addEventListener('click', function(){
      var open = menu.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', open);
    });
  }
  // Drawer open/close
  document.addEventListener('click', function(e){
    var opener = e.target.closest('[data-drawer-open]');
    if(opener){
      var id = opener.dataset.drawerOpen;
      var drawer = document.getElementById(id);
      if(drawer){ drawer.classList.add('is-open'); drawer.removeAttribute('aria-hidden'); document.body.style.overflow='hidden'; }
    }
    var closer = e.target.closest('[data-drawer-close]');
    if(closer){
      var id2 = closer.dataset.drawerClose;
      var d2 = id2 ? document.getElementById(id2) : closer.closest('.drawer');
      if(d2){ d2.classList.remove('is-open'); d2.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
    }
  });
  // Cart count update
  function updateCartCount(){
    fetch('/cart.js').then(function(r){ return r.json(); }).then(function(cart){
      var badges = document.querySelectorAll('[data-cart-count]');
      badges.forEach(function(b){
        b.textContent = cart.item_count;
        b.style.display = cart.item_count > 0 ? 'flex' : 'none';
      });
    }).catch(function(){});
  }
  updateCartCount();
  document.addEventListener('cart:updated', updateCartCount);
})();
</script>

