<style>
.site-footer { background: #1a1a2e; color: #ccc; padding: 60px 20px 20px; }
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 40px;
  max-width: 1200px;
  margin: 0 auto;
  padding-bottom: 40px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.footer-brand-name { color: #fff; font-size: 22px; font-weight: 800; margin-bottom: 15px; }
.footer-brand-name span { color: #00A651; }
.footer-desc { font-size: 14px; line-height: 1.8; margin-bottom: 20px; }
.footer-contact p { font-size: 14px; margin: 5px 0; }
.footer-contact a { color: #00A651; text-decoration: none; }
.footer-heading { color: #fff; font-size: 16px; font-weight: 700; margin-bottom: 20px; }
.footer-links { list-style: none; padding: 0; margin: 0; }
.footer-links li { margin-bottom: 10px; }
.footer-links a { color: #ccc; text-decoration: none; font-size: 14px; transition: color 0.3s; }
.footer-links a:hover { color: #00A651; }
.footer-bottom {
  text-align: center;
  padding-top: 20px;
  font-size: 13px;
  color: #888;
  max-width: 1200px;
  margin: 0 auto;
}
@media (max-width: 768px) {
  .footer-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 480px) {
  .footer-grid { grid-template-columns: 1fr; }
}
</style>

