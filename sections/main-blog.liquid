<style>
/* ===== AGILE BLOG - DARK THEME ===== */
body { background:#0a0a0c !important; }
.shopify-section { background:#0a0a0c; }

.agile-blog-wrap {
  background: #0a0a0c;
  min-height: 100vh;
  padding: 0 0 80px;
}

/* Hero banner */
.agile-blog-hero {
  position: relative;
  background: linear-gradient(135deg, #0a0a0c 0%, #0f1a2e 50%, #0a0a0c 100%);
  padding: 80px 24px 60px;
  text-align: center;
  overflow: hidden;
  border-bottom: 1px solid rgba(212,160,23,0.2);
}
.agile-blog-hero::before {
  content: 'SURGICAL HUB';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 120px;
  font-weight: 900;
  color: rgba(212,160,23,0.04);
  white-space: nowrap;
  pointer-events: none;
  letter-spacing: 10px;
}
.agile-blog-eyebrow {
  display: inline-block;
  background: rgba(212,160,23,0.1);
  border: 1px solid rgba(212,160,23,0.3);
  color: #D4A017;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  padding: 6px 18px;
  border-radius: 2px;
  margin-bottom: 20px;
}
.agile-blog-title {
  color: #ffffff !important;
  font-size: clamp(28px, 5vw, 48px) !important;
  font-weight: 800 !important;
  line-height: 1.2 !important;
  margin: 0 0 16px !important;
}
.agile-blog-title span { color: #D4A017; }
.agile-blog-subtitle {
  color: rgba(255,255,255,0.55);
  font-size: 16px;
  max-width: 560px;
  margin: 0 auto;
  line-height: 1.6;
}

/* Grid */
.agile-blog-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 28px;
  max-width: 1200px;
  margin: 60px auto 0;
  padding: 0 24px;
}

/* Card */
.article-card {
  background: linear-gradient(145deg, #111318, #0d1220) !important;
  border: 1px solid rgba(255,255,255,0.06) !important;
  border-radius: 12px !important;
  overflow: hidden !important;
  transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease !important;
  display: flex !important;
  flex-direction: column !important;
}
.article-card:hover {
  transform: translateY(-6px) !important;
  border-color: rgba(212,160,23,0.4) !important;
  box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(212,160,23,0.1) !important;
}

/* Image */
.article-card-img {
  display: block !important;
  width: 100% !important;
  height: 200px !important;
  background-size: cover !important;
  background-position: center !important;
  background-color: #0f1a2e !important;
  transition: transform 0.4s ease !important;
  overflow: hidden !important;
  text-decoration: none !important;
}
.article-card:hover .article-card-img {
  transform: scale(1.04) !important;
}
.article-card-img--placeholder {
  background: linear-gradient(135deg, #0f1a2e, #1a2540) !important;
  position: relative !important;
}
.article-card-img--placeholder::after {
  content: 'AGILE' !important;
  position: absolute !important;
  top: 50%; left: 50% !important;
  transform: translate(-50%,-50%) !important;
  color: rgba(212,160,23,0.3) !important;
  font-size: 28px !important;
  font-weight: 900 !important;
  letter-spacing: 4px !important;
}

/* Gold top line on card hover */
.article-card::before {
  content: '' !important;
  display: block !important;
  height: 3px !important;
  width: 0 !important;
  background: linear-gradient(90deg, #D4A017, #f0c040) !important;
  transition: width 0.4s ease !important;
}
.article-card:hover::before {
  width: 100% !important;
}

/* Body */
.article-card-body {
  padding: 24px !important;
  display: flex !important;
  flex-direction: column !important;
  flex: 1 !important;
}
.article-date {
  color: #D4A017 !important;
  font-size: 11px !important;
  font-weight: 700 !important;
  letter-spacing: 2px !important;
  text-transform: uppercase !important;
  margin-bottom: 12px !important;
  display: block !important;
}
.article-title {
  margin: 0 0 12px !important;
  font-size: 18px !important;
  font-weight: 700 !important;
  line-height: 1.4 !important;
}
.article-title a {
  color: #ffffff !important;
  text-decoration: none !important;
  transition: color 0.2s !important;
}
.article-title a:hover { color: #D4A017 !important; }
.article-excerpt {
  color: rgba(255,255,255,0.5) !important;
  font-size: 14px !important;
  line-height: 1.7 !important;
  flex: 1 !important;
  margin-bottom: 20px !important;
}
.article-read-more {
  display: inline-flex !important;
  align-items: center !important;
  gap: 8px !important;
  color: #D4A017 !important;
  font-size: 13px !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
  letter-spacing: 1.5px !important;
  text-decoration: none !important;
  border-bottom: 1px solid rgba(212,160,23,0.3) !important;
  padding-bottom: 4px !important;
  transition: gap 0.2s, border-color 0.2s !important;
  align-self: flex-start !important;
}
.article-read-more:hover {
  gap: 14px !important;
  border-color: #D4A017 !important;
}

/* Pagination */
.agile-pagination {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 60px;
  padding: 0 24px;
}
.agile-pagination a,
.agile-pagination span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px; height: 40px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  color: #fff;
  border-radius: 6px;
  font-size: 14px;
  text-decoration: none;
  transition: all 0.2s;
}
.agile-pagination a:hover,
.agile-pagination span.current {
  background: #D4A017;
  border-color: #D4A017;
  color: #000;
  font-weight: 700;
}

/* Empty state */
.agile-blog-empty {
  text-align: center;
  padding: 80px 24px;
  color: rgba(255,255,255,0.4);
}
.agile-blog-empty h3 { color: #fff; margin-bottom: 12px; }
</style>

{%- paginate blog.articles by 12 -%}

<div class="agile-blog-wrap">
  <div class="agile-blog-hero">
    <div class="agile-blog-eyebrow">Knowledge Hub</div>
    <h1 class="agile-blog-title">{{ blog.title | replace: 'Diagnostics', '<span>Diagnostics</span>' | replace: 'Ortho', '<span>Ortho</span>' | replace: 'Surgical', '<span>Surgical</span>' }}</h1>
    <p class="agile-blog-subtitle">Clinical insights, product updates and surgical techniques from Agile Healthcare — Telangana's leading Meril distributor.</p>
  </div>

  {%- if blog.articles_count > 0 -%}
    <div class="agile-blog-grid">
      {%- for article in blog.articles -%}
        <article class="article-card">
          {%- if article.image -%}
            <a href="{{ article.url }}" class="article-card-img" style="background-image:url('{{ article.image | image_url: width: 600 }}')"></a>
          {%- else -%}
            <a href="{{ article.url }}" class="article-card-img article-card-img--placeholder"></a>
          {%- endif -%}
          <div class="article-card-body">
            <time class="article-date">{{ article.published_at | date: "%b %d, %Y" }}</time>
            <h2 class="article-title"><a href="{{ article.url }}">{{ article.title }}</a></h2>
            <p class="article-excerpt">{{ article.excerpt | strip_html | truncate: 130 }}</p>
            <a href="{{ article.url }}" class="article-read-more">Read More &rarr;</a>
          </div>
        </article>
      {%- endfor -%}
    </div>
  {%- else -%}
    <div class="agile-blog-empty">
      <h3>Coming Soon</h3>
      <p>Clinical articles and product insights will appear here.</p>
    </div>
  {%- endif -%}

  {%- if paginate.pages > 1 -%}
    <div class="agile-pagination">
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}">&laquo;</a>
      {%- endif -%}
      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}
          <a href="{{ part.url }}">{{ part.title }}</a>
        {%- else -%}
          <span class="current">{{ part.title }}</span>
        {%- endif -%}
      {%- endfor -%}
      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}">&raquo;</a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{%- endpaginate -%}

{% schema %}
{
  "name": "Blog",
  "settings": [],
  "presets": [{ "name": "Blog" }]
}
{% endschema %}