{%- paginate blog.articles by 12 -%}
<div class="container" style="padding:32px 24px;">
  <h1 style="color:#fff;font-size:32px;margin-bottom:24px;">{{ blog.title }}</h1>
  <div class="articles-grid">
    {%- for article in blog.articles -%}
      <article class="article-card">
        {%- if article.image -%}
          <a href="{{ article.url }}" class="article-card-img" style="background-image:url('{{ article.image | image_url: width: 600 }}')"></a>
        {%- else -%}
          <a href="{{ article.url }}" class="article-card-img article-card-img--placeholder"></a>
        {%- endif -%}
        <div class="article-card-body">
          <time class="article-date">{{ article.published_at | date: "%b %d, %Y" }}</time>
          <h2 class="article-title"><a href="{{ article.url }}">{{ article.title }}</a></h2>
          <p class="article-excerpt">{{ article.excerpt | strip_html | truncate: 120 }}</p>
          <a href="{{ article.url }}" class="article-read-more">Read More →</a>
        </div>
      </article>
    {%- endfor -%}
  </div>
  {%- render 'pagination', paginate: paginate -%}
</div>
{%- endpaginate -%}

{% schema %}
{"name":"Blog","settings":[],"presets":[{"name":"Blog"}]}
{% endschema %}
