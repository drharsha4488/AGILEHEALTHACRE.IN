{%- comment -%}Related Products section{%- endcomment -%}
{%- assign related = product.metafields.custom.related_products.value -%}
{%- if related == blank or related.size == 0 -%}
  {%- assign related = recommendations.products | default: collection.products -%}
{%- endif -%}

{%- if related != blank and related.size > 0 -%}
  <section class="related-products-section" style="padding:48px 0;border-top:1px solid var(--border)">
    <div class="container">
      <div class="section-heading">
        <h2>{{ section.settings.heading | default: 'You may also like' }}</h2>
        <a href="/collections/all" class="link">View all →</a>
      </div>
      <div class="carousel">
        <button class="carousel-btn prev" aria-label="Previous">‹</button>
        <div class="carousel-track">
          {%- for p in related limit: section.settings.product_count -%}
            {%- render 'product-card-grid', product: p -%}
          {%- endfor -%}
        </div>
        <button class="carousel-btn next" aria-label="Next">›</button>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Related Products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "You may also like" },
    { "type": "range", "id": "product_count", "label": "Number of products", "min": 4, "max": 12, "step": 1, "default": 6 }
  ],
  "presets": [{ "name": "Related Products" }]
}
{% endschema %}
