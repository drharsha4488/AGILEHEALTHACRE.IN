{%- assign img_pos = section.settings.image_position | default: "left" -%}
<section class="image-with-text section-pad">
  <div class="container">
    <div class="iwt-grid iwt-grid--{{ img_pos }}">
      <div class="iwt-image">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 800 | image_tag: loading: "lazy", class: "iwt-img" }}
        {%- else -%}
          <div class="iwt-placeholder">{{ 'image' | placeholder_svg_tag }}</div>
        {%- endif -%}
      </div>
      <div class="iwt-text">
        {%- if section.settings.overline != blank -%}
          <span class="section-tag">{{ section.settings.overline }}</span>
        {%- endif -%}
        <h2 class="iwt-heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.body != blank -%}
          <div class="iwt-body">{{ section.settings.body }}</div>
        {%- endif -%}
        {%- if section.settings.button_text != blank -%}
          <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn-primary">{{ section.settings.button_text }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
<style>
.iwt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.iwt-grid--right .iwt-image { order: 2; }
.iwt-grid--right .iwt-text { order: 1; }
.iwt-img { width: 100%; border-radius: 12px; display: block; }
.iwt-placeholder { background: #1a2a40; border-radius: 12px; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; color: #8899aa; }
.iwt-heading { font-size: 32px; font-weight: 700; color: #fff; margin: 12px 0; }
.iwt-body { color: #8899aa; line-height: 1.7; margin-bottom: 24px; }
@media(max-width:768px){ .iwt-grid { grid-template-columns: 1fr; gap: 32px; } .iwt-grid--right .iwt-image { order: 0; } }
</style>

{% schema %}
{
  "name": "Image with Text",
  "settings": [
    {"type":"image_picker","id":"image","label":"Image"},
    {"type":"select","id":"image_position","label":"Image position","options":[{"value":"left","label":"Left"},{"value":"right","label":"Right"}],"default":"left"},
    {"type":"text","id":"overline","label":"Overline tag"},
    {"type":"text","id":"heading","label":"Heading","default":"Quality Medical Devices"},
    {"type":"textarea","id":"body","label":"Body text"},
    {"type":"text","id":"button_text","label":"Button text"},
    {"type":"url","id":"button_url","label":"Button URL"}
  ],
  "presets": [{"name":"Image with Text"}]
}
{% endschema %}
