{%- if customer -%}
<div class="container" style="padding:32px 24px;max-width:900px;">
  <h1 style="color:#fff;font-size:28px;margin-bottom:8px;">Saved Addresses</h1>
  <p style="color:#8899aa;margin-bottom:28px;">Manage your shipping and billing addresses.</p>

  <div style="margin-bottom:28px;">
    <button onclick="document.getElementById('new-address-form').style.display='block';this.style.display='none';" class="btn btn-primary">+ Add New Address</button>
    <div id="new-address-form" style="display:none;background:#0a1628;border:1px solid #1a2a40;border-radius:10px;padding:24px;margin-top:16px;">
      <h3 style="color:#fff;margin-bottom:16px;">New Address</h3>
      {%- form 'customer_address', customer.new_address -%}
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          <div class="form-group"><label>First Name</label><input type="text" name="address[first_name]" placeholder="First name"></div>
          <div class="form-group"><label>Last Name</label><input type="text" name="address[last_name]" placeholder="Last name"></div>
        </div>
        <div class="form-group"><label>Company</label><input type="text" name="address[company]" placeholder="Hospital/Clinic name"></div>
        <div class="form-group"><label>Address</label><input type="text" name="address[address1]" required placeholder="Street address"></div>
        <div class="form-group"><label>Apartment/Suite</label><input type="text" name="address[address2]" placeholder="Apartment, suite, etc."></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          <div class="form-group"><label>City</label><input type="text" name="address[city]" required></div>
          <div class="form-group"><label>PIN Code</label><input type="text" name="address[zip]"></div>
        </div>
        <div class="form-group"><label>Phone</label><input type="tel" name="address[phone]"></div>
        <div style="margin:12px 0;"><label style="display:flex;gap:8px;color:#ccd6e0;font-size:14px;cursor:pointer;"><input type="checkbox" name="address[default]" value="1"> Set as default address</label></div>
        <div style="display:flex;gap:12px;">
          <button type="submit" class="btn btn-primary">Save Address</button>
          <button type="button" onclick="document.getElementById('new-address-form').style.display='none';" class="btn btn-outline">Cancel</button>
        </div>
      {%- endform -%}
    </div>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;">
    {%- for address in customer.addresses -%}
      <div style="background:#0a1628;border:1px solid {% if address == customer.default_address %}#00A651{% else %}#1a2a40{% endif %};border-radius:10px;padding:20px;">
        {%- if address == customer.default_address -%}
          <span style="font-size:11px;background:rgba(0,166,81,0.1);color:#00A651;padding:2px 8px;border-radius:20px;margin-bottom:10px;display:inline-block;">Default</span>
        {%- endif -%}
        <address style="font-style:normal;color:#ccd6e0;font-size:14px;line-height:1.8;margin-bottom:14px;">
          <strong style="color:#fff;">{{ address.name }}</strong><br>
          {%- if address.company != blank -%}{{ address.company }}<br>{%- endif -%}
          {{ address.address1 }}<br>
          {%- if address.address2 != blank -%}{{ address.address2 }}<br>{%- endif -%}
          {{ address.city }}, {{ address.zip }}<br>
          {{ address.country }}
        </address>
        <div style="display:flex;gap:10px;">
          <a href="#" onclick="document.getElementById('edit-{{ address.id }}').style.display='block';return false;" style="color:#00A651;font-size:13px;text-decoration:none;">Edit</a>
          <a href="{{ address.url }}" data-method="delete" style="color:#ff4444;font-size:13px;text-decoration:none;" onclick="return confirm('Remove this address?')">Remove</a>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{"name":"Addresses","settings":[],"presets":[{"name":"Addresses"}]}
{% endschema %}
