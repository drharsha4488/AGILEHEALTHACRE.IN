<style>
.divisions-section { padding: 90px 20px; background: #050d1a; }
.section-header { text-align: center; margin-bottom: 55px; }
.section-tag { color: #00A651; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 3px; margin-bottom: 12px; }
.section-title { font-size: 38px; font-weight: 900; color: #fff; margin-bottom: 12px; letter-spacing: -1px; }
.section-subtitle { color: rgba(255,255,255,0.5); font-size: 16px; max-width: 560px; margin: 0 auto; line-height: 1.7; }
.divisions-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2px;
  max-width: 1200px;
  margin: 0 auto;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.05);
}
.division-card {
  background: #080f1e;
  padding: 38px 32px;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
  cursor: pointer;
}
.division-card::before {
  content: "";
  position: absolute; top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, #0057A8, #00A651);
  transform: scaleX(0);
  transition: transform 0.3s;
  transform-origin: left;
}
.division-card:hover::before { transform: scaleX(1); }
.division-card:hover { background: #0d1a2e; }
.division-icon { font-size: 32px; margin-bottom: 18px; }
.division-name { font-size: 18px; font-weight: 700; color: #fff; margin-bottom: 6px; }
.division-sku { font-size: 12px; color: #00A651; font-weight: 600; letter-spacing: 1px; margin-bottom: 12px; text-transform: uppercase; }
.division-desc { color: rgba(255,255,255,0.5); font-size: 14px; line-height: 1.7; }
.division-arrow { color: #00A651; font-size: 18px; margin-top: 16px; display: inline-block; transition: transform 0.3s; }
.division-card:hover .division-arrow { transform: translateX(5px); }
</style>

<section class="divisions-section">
  <div class="section-header">
    <div class="section-tag">16 Clinical Divisions</div>
    <h2 class="section-title">Clinical Solutions</h2>
    <p class="section-subtitle">1,202+ medical devices across every surgical specialty — delivered in 2 hours across all 33 Telangana districts.</p>
  </div>
  <div class="divisions-grid">
    <div class="division-card">
      <div class="division-icon">🦴</div>
      <div class="division-name">Trauma & Fracture</div>
      <div class="division-sku">200+ SKUs</div>
      <p class="division-desc">Plating systems, intramedullary nails, and fracture fixation devices for all trauma scenarios.</p>
      <div class="division-arrow">→</div>
    </div>
    <div class="division-card">
      <div class="division-icon">🦿</div>
      <div class="division-name">Arthroplasty</div>
      <div class="division-sku">200+ SKUs</div>
      <p class="division-desc">Complete joint replacement solutions — knee, hip, and shoulder systems with anatomical sizing wizards.</p>
      <div class="division-arrow">→</div>
    </div>
    <div class="division-card">
      <div class="division-icon">❤️</div>
      <div class="division-name">Cardiovascular</div>
      <div class="division-sku">200+ SKUs</div>
      <p class="division-desc">Coronary stents, heart valves, and vascular intervention devices from Meril Life Sciences.</p>
      <div class="division-arrow">→</div>
    </div>
    <div class="division-card">
      <div class="division-icon">🔬</div>
      <div class="division-name">Endo-Surgery</div>
      <div class="division-sku">200+ SKUs</div>
      <p class="division-desc">Laparoscopic instrumentation and minimally invasive surgical tools for precision procedures.</p>
      <div class="division-arrow">→</div>
    </div>
    <div class="division-card">
      <div class="division-icon">🧪</div>
      <div class="division-name">Diagnostics</div>
      <div class="division-sku">200+ SKUs</div>
      <p class="division-desc">Lab analyzers, test kits, and diagnostic equipment for hospitals and surgical centers.</p>
      <div class="division-arrow">→</div>
    </div>
    <div class="division-card">
      <div class="division-icon">🚚</div>
      <div class="division-name">2-Hour OT Dispatch</div>
      <div class="division-sku">All 33 Districts</div>
      <p class="division-desc">Hub-and-spoke logistics network ensuring emergency surgical supply reaches your OT within 2 hours statewide.</p>
      <div class="division-arrow">→</div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Clinical Divisions", "settings": [] }
{% endschema %}