<style>
.product-page-wrap { max-width: 1280px; margin: 0 auto; padding: 32px 24px; }
.product-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
.product-gallery { position: sticky; top: 80px; }
.product-gallery-main { aspect-ratio: 1; border-radius: 10px; overflow: hidden; background: #0a1628; margin-bottom: 12px; }
.product-gallery-main img { width: 100%; height: 100%; object-fit: contain; }
.product-gallery-main-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #8899aa; }
.product-gallery-thumbs { display: flex; gap: 8px; flex-wrap: wrap; }
.thumb { width: 70px; height: 70px; border-radius: 6px; overflow: hidden; cursor: pointer; border: 2px solid transparent; background: #0a1628; transition: border-color 0.2s; flex-shrink: 0; }
.thumb img { width: 100%; height: 100%; object-fit: cover; }
.thumb.active, .thumb:hover { border-color: #00A651; }
.product-info { }
.product-breadcrumbs { font-size: 12px; color: #8899aa; margin-bottom: 16px; }
.product-breadcrumbs a { color: #8899aa; text-decoration: none; }
.product-breadcrumbs a:hover { color: #00A651; }
.product-vendor { font-size: 12px; color: #00A651; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; display: inline-block; background: rgba(0,166,81,0.1); padding: 3px 10px; border-radius: 20px; }
.product-title { font-size: 28px; font-weight: 700; color: #fff; margin: 0 0 16px; line-height: 1.3; }
.product-price-wrap { margin-bottom: 16px; }
.product-price { font-size: 26px; font-weight: 700; color: #00A651; }
.product-price-compare { font-size: 16px; color: #8899aa; text-decoration: line-through; margin-left: 8px; }
.availability-badge { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 500; padding: 4px 12px; border-radius: 20px; margin-bottom: 16px; }
.availability-badge--in { background: rgba(0,166,81,0.1); color: #00A651; }
.availability-badge--out { background: rgba(255,68,68,0.1); color: #ff4444; }
.availability-badge--low { background: rgba(255,165,0,0.1); color: orange; }
.availability-badge::before { content: "●"; font-size: 8px; }
.product-short-desc { color: #8899aa; font-size: 14px; line-height: 1.6; margin-bottom: 24px; border-bottom: 1px solid #1a2a40; padding-bottom: 20px; }
.product-form { }
.product-form-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 16px; }
.btn-add-to-cart { background: #00A651; color: #fff; border: none; padding: 14px 28px; border-radius: 8px; font-size: 15px; font-weight: 600; cursor: pointer; flex: 1; transition: background 0.2s; }
.btn-add-to-cart:hover { background: #008f44; }
.btn-quote { background: transparent; border: 1px solid #00A651; color: #00A651; padding: 14px 20px; border-radius: 8px; font-size: 14px; font-weight: 500; cursor: pointer; transition: all 0.2s; }
.btn-quote:hover { background: rgba(0,166,81,0.1); }
.trust-badges { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 20px; }
.trust-badge { display: flex; align-items: center; gap: 6px; font-size: 11px; color: #8899aa; background: #0a1628; border: 1px solid #1a2a40; border-radius: 20px; padding: 5px 12px; }
.trust-badge svg { color: #00A651; }
.product-tabs-wrap { margin-top: 48px; }
.related-products { margin-top: 60px; }
.related-products h2 { font-size: 22px; color: #fff; margin-bottom: 24px; }
@media(max-width:900px){ .product-layout { grid-template-columns: 1fr; } .product-gallery { position: static; } }
</style>

<div class="product-page-wrap">
  <div class="product-layout">
    <!-- Gallery -->
    <div class="product-gallery">
      <div class="product-gallery-main">
        {%- if product.featured_image -%}
          <img id="product-main-img" src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.featured_image.alt | escape }}" loading="eager">
        {%- else -%}
          <div class="product-gallery-main-placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
        {%- endif -%}
      </div>
      {%- if product.images.size > 1 -%}
        <div class="product-gallery-thumbs">
          {%- for image in product.images -%}
            <div class="thumb{% if forloop.first %} active{% endif %}" data-src="{{ image | image_url: width: 800 }}" data-idx="{{ forloop.index0 }}">
              <img src="{{ image | image_url: width: 150 }}" alt="{{ image.alt | escape }}" loading="lazy">
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Info -->
    <div class="product-info">
      <div class="product-breadcrumbs">
        <a href="/">Home</a> &rsaquo;
        {%- if product.collections.first -%}
          <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a> &rsaquo;
        {%- endif -%}
        <span>{{ product.title }}</span>
      </div>

      {%- if product.vendor != blank -%}
        <span class="product-vendor">{{ product.vendor }}</span>
      {%- endif -%}

      <h1 class="product-title">{{ product.title }}</h1>

      <div class="product-price-wrap">
        {%- render 'price', product: product -%}
      </div>

      {%- if product.available -%}
        {%- assign inventory_qty = product.selected_or_first_available_variant.inventory_quantity -%}
        {%- if inventory_qty > 10 -%}
          <span class="availability-badge availability-badge--in">In Stock</span>
        {%- elsif inventory_qty > 0 -%}
          <span class="availability-badge availability-badge--low">Low Stock — {{ inventory_qty }} left</span>
        {%- else -%}
          <span class="availability-badge availability-badge--in">Available</span>
        {%- endif -%}
      {%- else -%}
        <span class="availability-badge availability-badge--out">Out of Stock</span>
      {%- endif -%}

      <div class="product-short-desc">{{ product.description | strip_html | truncate: 200 }}</div>

      {%- form 'product', product, data-product-form: '', data-product-id: product.id -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        {%- render 'variant-picker', product: product -%}
        {%- render 'quantity-input' -%}

        <div class="product-form-actions">
          {%- if product.tags contains 'quote-only' -%}
            <button type="button" class="btn-add-to-cart" data-open-quote>Request a Quote</button>
          {%- else -%}
            <button type="submit" name="add" class="btn-add-to-cart" data-add-to-cart>
              {%- if product.available -%}Add to Cart{%- else -%}Out of Stock{%- endif -%}
            </button>
            <button type="button" class="btn-quote" data-open-quote>Request a Quote</button>
          {%- endif -%}
        </div>

        <div class="trust-badges">
          <span class="trust-badge"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>CDSCO Licensed</span>
          <span class="trust-badge"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>ISO 13485</span>
          <span class="trust-badge"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>GMP Certified</span>
          <span class="trust-badge"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>2-Hr Dispatch</span>
        </div>
      {%- endform -%}
    </div>
  </div>

  <!-- Product Tabs -->
  <div class="product-tabs-wrap">
    {%- render 'product-tabs', product: product -%}
  </div>

  <!-- Related -->
  <div class="related-products">
    <h2>Related Products</h2>
    <div id="product-recommendations" class="product-grid product-grid--4"></div>
  </div>
</div>

{%- render 'request-quote-form', product: product -%}

<script>
(function(){
  // Thumbnail switcher
  var mainImg = document.getElementById('product-main-img');
  document.querySelectorAll('.thumb').forEach(function(thumb){
    thumb.addEventListener('click', function(){
      if(mainImg) mainImg.src = this.dataset.src;
      document.querySelectorAll('.thumb').forEach(function(t){ t.classList.remove('active'); });
      this.classList.add('active');
    });
  });

  // Add to cart
  var form = document.querySelector('[data-product-form]');
  if(form){
    form.addEventListener('submit', function(e){
      var btn = form.querySelector('[data-add-to-cart]');
      if(!btn) return;
      e.preventDefault();
      btn.disabled = true; btn.textContent = 'Adding...';
      var fd = new FormData(form);
      fetch('/cart/add.js', { method: 'POST', body: fd })
        .then(function(r){ return r.json(); })
        .then(function(){
          btn.textContent = 'Added!';
          document.dispatchEvent(new Event('cart:updated'));
          var drawer = document.getElementById('cart-drawer');
          if(drawer){ drawer.classList.add('is-open'); drawer.removeAttribute('aria-hidden'); document.body.style.overflow='hidden'; }
          setTimeout(function(){ btn.disabled=false; btn.textContent='Add to Cart'; }, 2000);
        }).catch(function(){ btn.disabled=false; btn.textContent='Add to Cart'; });
    });
  }

  // Product recommendations
  var recContainer = document.getElementById('product-recommendations');
  if(recContainer){
    var pid = recContainer.closest('[data-product-id]') || document.querySelector('[data-product-id]');
    var productId = pid ? pid.dataset.productId : null;
    if(productId){
      fetch('/recommendations/products.json?product_id='+productId+'&limit=4')
        .then(function(r){ return r.json(); })
        .then(function(data){
          if(data.products && data.products.length){
            recContainer.innerHTML = data.products.map(function(p){
              return '<a href="'+p.url+'" class="product-card"><div class="product-card-media" style="background-image:url(\''+p.featured_image+'\')"></div><div class="product-card-info"><div class="product-card-title">'+p.title+'</div></div></a>';
            }).join('');
          }
        }).catch(function(){});
    }
  }
})();
</script>

{% schema %}
{"name":"Main Product","settings":[],"presets":[{"name":"Main Product"}]}
{% endschema %}
