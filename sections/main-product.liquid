{{ 'product-page.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-page.js' | asset_url }}" defer></script>

<div class="product-page-wrap" data-product-id="{{ product.id }}" data-product-handle="{{ product.handle }}">
  {%- assign current_variant = product.selected_or_first_available_variant -%}

  <div class="product-gallery">
    <div class="product-gallery-thumbs">
      {%- for image in product.images -%}
        <button type="button" class="product-gallery-thumb {% if forloop.first %}active{% endif %}"
          data-gallery-thumb data-fullsrc="{{ image | image_url: width: 1200 }}" aria-label="View image {{ forloop.index }}">
          <img src="{{ image | image_url: width: 180 }}" alt="{{ image.alt | escape }}" loading="lazy" width="88" height="88">
        </button>
      {%- endfor -%}
    </div>
    <div class="product-gallery-main zoom-container" data-zoom-container>
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 1400 }}"
             alt="{{ product.featured_image.alt | escape }}"
             data-gallery-main-img class="zoom-main"
             width="1400" height="1400">
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag }}
      {%- endif -%}
      <div class="zoom-lens"></div>
      <div class="zoom-result"></div>
    </div>
    <div class="gallery-dots">
      {%- for image in product.images -%}
        <span class="dot {% if forloop.first %}active{% endif %}" data-gallery-dot></span>
      {%- endfor -%}
    </div>
  </div>

  <div class="product-info">
    {%- render 'breadcrumbs' -%}

    {%- if product.vendor != blank -%}
      <div class="product-brand-badge">{{ product.vendor }}</div>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'title' -%}
          <h1 class="product-title" {{ block.shopify_attributes }}>{{ product.title | escape }}</h1>
        {%- when 'rating' -%}
          {%- render 'star-rating', product: product -%}
        {%- when 'price' -%}
          <div class="product-price-block" {{ block.shopify_attributes }}>
            {%- render 'price', product: product, show_volume: true -%}
          </div>
          {%- render 'customer-pricing', product: product -%}
        {%- when 'inventory' -%}
          {%- render 'inventory-status', variant: current_variant -%}
        {%- when 'variant_picker' -%}
          {%- unless product.has_only_default_variant -%}
            <div class="product-variant-picker" {{ block.shopify_attributes }}>
              {%- render 'variant-picker', product: product -%}
            </div>
          {%- endunless -%}
        {%- when 'volume_pricing' -%}
          {%- render 'volume-pricing', product: product -%}
        {%- when 'description' -%}
          {%- comment -%} description shown in tab below {%- endcomment -%}
        {%- when 'share' -%}
          <div class="wishlist-share-row">
            {%- render 'wishlist-button', product: product -%}
            {%- render 'share-buttons' -%}
          </div>
        {%- when 'custom_liquid' -%}
          <div {{ block.shopify_attributes }}>{{ block.settings.custom_liquid }}</div>
        {%- when '@app' -%}
          {%- render block -%}
      {%- endcase -%}
    {%- endfor -%}

    <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data"
          data-product-form id="product-form-{{ section.id }}" novalidate>
      <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

      <div class="product-meta-row">
        <div><span class="label">SKU:</span><span class="val">{{ current_variant.sku | default: 'AH-' | append: product.id }}</span></div>
        {%- if product.metafields.custom.regulatory_approvals -%}
          <div><span class="label">Reg:</span><span class="val">{{ product.metafields.custom.regulatory_approvals | join: ' · ' }}</span></div>
        {%- endif -%}
      </div>

      {%- render 'line-item-properties' -%}
      {%- render 'selling-plans', product: product -%}

      <div style="display:flex;gap:10px;align-items:end;margin-top:8px">
        {%- render 'quantity-input', product: product -%}
      </div>

      <div class="product-buy-buttons">
        {%- if product.tags contains 'quote-only' -%}
          <a href="/pages/quote?product={{ product.handle }}" class="btn btn-blue btn-lg btn-block" data-open-quote>
            Request a Quote
          </a>
        {%- else -%}
          <button type="submit" class="btn btn-primary btn-lg btn-block"
                  data-add-to-cart
                  {% if current_variant.available == false %}disabled{% endif %}>
            {%- if current_variant.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
          </button>
          <a href="/pages/quote?product={{ product.handle }}" class="btn btn-secondary btn-block">
            Request a Quote
          </a>
        {%- endif -%}
      </div>
    </form>

    {%- render 'shipping-estimate' -%}

    <div class="product-trust-bar" aria-label="Trust signals">
      <div class="trust-item"><div class="trust-icon">⚡</div>2-Hr Dispatch</div>
      <div class="trust-item"><div class="trust-icon">✓</div>CDSCO Approved</div>
      <div class="trust-item"><div class="trust-icon">⚙</div>ISO 13485</div>
      <div class="trust-item"><div class="trust-icon">↺</div>Easy Returns</div>
    </div>
  </div>
</div>

<nav class="product-tabs-sticky-nav" aria-label="Product details navigation">
  <div class="container">
    <a href="#description">Description</a>
    <a href="#specifications">Specifications</a>
    <a href="#technique">Surgical Technique</a>
    <a href="#documents">Documents</a>
    <a href="#reviews">Reviews</a>
    <a href="#qa">Q&amp;A</a>
  </div>
</nav>

<section id="description" class="product-tab-panel">
  <h2>Description</h2>
  <div class="rte">{{ product.description }}</div>
</section>

<section id="specifications" class="product-tab-panel">
  <h2>Specifications</h2>
  {%- if product.metafields.custom.specifications -%}
    <div class="rte">{{ product.metafields.custom.specifications | metafield_tag }}</div>
  {%- else -%}
    <table>
      <tr><th>Vendor</th><td>{{ product.vendor }}</td></tr>
      <tr><th>SKU</th><td>{{ current_variant.sku }}</td></tr>
      <tr><th>Product Type</th><td>{{ product.type }}</td></tr>
      {%- if product.metafields.custom.regulatory_approvals -%}
        <tr><th>Regulatory</th><td>{{ product.metafields.custom.regulatory_approvals | join: ', ' }}</td></tr>
      {%- endif -%}
      {%- if product.metafields.custom.minimum_order_qty -%}
        <tr><th>Minimum Order Qty</th><td>{{ product.metafields.custom.minimum_order_qty }}</td></tr>
      {%- endif -%}
    </table>
  {%- endif -%}
</section>

<section id="technique" class="product-tab-panel">
  <h2>Surgical Technique</h2>
  {%- if product.metafields.custom.surgical_technique_pdf -%}
    <p><a href="{{ product.metafields.custom.surgical_technique_pdf | file_url }}" class="btn btn-secondary" target="_blank" rel="noopener">⬇ Download Surgical Technique Guide (PDF)</a></p>
  {%- else -%}
    <p class="text-mute">Surgical technique guide available on request. Please contact our clinical team at <a href="mailto:info@agilehealthcare.in">info@agilehealthcare.in</a>.</p>
  {%- endif -%}
</section>

<section id="documents" class="product-tab-panel">
  <h2>Documents &amp; Downloads</h2>
  {%- if product.metafields.custom.downloads -%}
    <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:8px">
      {%- for doc in product.metafields.custom.downloads.value -%}
        <li><a href="{{ doc | file_url }}" target="_blank" rel="noopener" class="btn btn-secondary">⬇ {{ doc.name | default: 'Download document' }}</a></li>
      {%- endfor -%}
    </ul>
  {%- else -%}
    <p class="text-mute">IFU, MSDS, certificates available upon request.</p>
  {%- endif -%}
</section>

<section id="reviews" class="product-tab-panel">
  <h2>Customer Reviews</h2>
  <div class="reviews-summary">
    <div>
      <div class="big-score">{{ product.metafields.reviews.rating_avg | default: '—' }}</div>
      <div class="text-mute">{{ product.metafields.reviews.rating_count | default: 0 }} reviews</div>
    </div>
    <div class="bars">
      {%- for i in (1..5) reversed -%}
        <div class="bar"><span>{{ i }}★</span><span class="track"><span class="fill" style="width:{{ 20 | times: i }}%"></span></span><span>—</span></div>
      {%- endfor -%}
    </div>
  </div>
  <p class="text-mute mt-4">Reviews powered by Shopify Product Reviews. Verified buyers only.</p>
</section>

<section id="qa" class="product-tab-panel">
  <h2>Questions &amp; Answers</h2>
  <details class="qa-item"><summary>Is this product CDSCO approved?</summary><div class="answer">Yes, all products carried by AgileHealthcare meet CDSCO regulatory requirements for the Indian market.</div></details>
  <details class="qa-item"><summary>What is the typical delivery time?</summary><div class="answer">2 hours within Hyderabad city, same-day across Telangana, 1–3 days pan-India.</div></details>
  <details class="qa-item"><summary>Do you offer bulk discounts?</summary><div class="answer">Yes — see the volume pricing table above, or contact us for institutional pricing.</div></details>
  <p class="mt-6"><a href="/pages/contact?subject=Question+about+{{ product.title | url_encode }}" class="btn btn-secondary">Ask a Question</a></p>
</section>

{%- render 'sticky-cart-bar', product: product, variant: current_variant -%}
{%- render 'size-guide-modal' -%}

{% section 'related-products' %}
{% section 'recently-viewed' %}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "image": [{{ product.featured_image | image_url: width: 1200 | json }}],
  "description": {{ product.description | strip_html | truncatewords: 50 | json }},
  "sku": {{ current_variant.sku | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  "offers": {
    "@type": "Offer",
    "url": {{ shop.url | append: product.url | json }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": "{{ current_variant.price | money_without_currency | strip_html | remove: ',' }}",
    "availability": "{% if current_variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}"
  }
}
</script>

{% schema %}
{
  "name": "Main Product",
  "tag": "section",
  "class": "section-main-product",
  "settings": [
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": true },
    { "type": "checkbox", "id": "enable_sticky_cart", "label": "Enable sticky cart bar", "default": true }
  ],
  "blocks": [
    { "type": "vendor", "name": "Vendor", "limit": 1 },
    { "type": "title", "name": "Title", "limit": 1 },
    { "type": "rating", "name": "Rating", "limit": 1 },
    { "type": "price", "name": "Price", "limit": 1 },
    { "type": "inventory", "name": "Inventory", "limit": 1 },
    { "type": "variant_picker", "name": "Variant Picker", "limit": 1 },
    { "type": "volume_pricing", "name": "Volume Pricing", "limit": 1 },
    { "type": "quantity", "name": "Quantity Selector", "limit": 1 },
    { "type": "buy_buttons", "name": "Buy Buttons", "limit": 1 },
    { "type": "description", "name": "Description" },
    { "type": "specs", "name": "Specifications" },
    { "type": "share", "name": "Share + Wishlist", "limit": 1 },
    {
      "type": "custom_liquid",
      "name": "Custom Liquid",
      "settings": [
        { "type": "liquid", "id": "custom_liquid", "label": "Liquid code" }
      ]
    },
    { "type": "@app" }
  ],
  "default": {
    "blocks": [
      { "type": "title" },
      { "type": "rating" },
      { "type": "price" },
      { "type": "inventory" },
      { "type": "variant_picker" },
      { "type": "quantity" },
      { "type": "buy_buttons" },
      { "type": "share" }
    ]
  },
  "presets": [{ "name": "Main Product" }]
}
{% endschema %}
