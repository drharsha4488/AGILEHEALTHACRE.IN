{%- comment -%}Frequently bought together bundle{%- endcomment -%}
{%- assign bundle = product.metafields.custom.bundle_with.value -%}
{%- if bundle != blank and bundle.size > 0 -%}
  {%- assign total = product.price -%}
  {%- for p in bundle -%}
    {%- assign total = total | plus: p.price -%}
  {%- endfor -%}

  <section class="frequently-bought-section" style="padding:48px 0;border-top:1px solid var(--border)">
    <div class="container">
      <div class="section-heading">
        <h2>{{ section.settings.heading | default: 'Frequently Bought Together' }}</h2>
      </div>
      <form action="{{ routes.cart_add_url }}" method="post" id="bundle-form-{{ section.id }}">
        <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px">
          <a href="{{ product.url }}" class="product-card" style="flex:1;min-width:180px;max-width:220px;text-decoration:none">
            <div class="product-card-media"><img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" loading="lazy"></div>
            <div class="product-card-body">
              <div class="product-card-title">{{ product.title }}</div>
              <div class="product-card-price">{{ product.price | money }}</div>
            </div>
          </a>
          <input type="hidden" name="items[][id]" value="{{ product.selected_or_first_available_variant.id }}">
          {%- for p in bundle limit: 2 -%}
            <span style="font-size:28px;color:var(--text-3)">+</span>
            <a href="{{ p.url }}" class="product-card" style="flex:1;min-width:180px;max-width:220px;text-decoration:none">
              <div class="product-card-media"><img src="{{ p.featured_image | image_url: width: 400 }}" alt="{{ p.title | escape }}" loading="lazy"></div>
              <div class="product-card-body">
                <div class="product-card-title">{{ p.title }}</div>
                <div class="product-card-price">{{ p.price | money }}</div>
              </div>
            </a>
            <input type="hidden" name="items[][id]" value="{{ p.selected_or_first_available_variant.id }}">
          {%- endfor -%}
          <div style="display:flex;flex-direction:column;gap:8px;min-width:200px">
            <div style="font-size:13px;color:var(--text-2)">Bundle total</div>
            <div style="font-size:28px;font-weight:800;color:var(--green);letter-spacing:-0.02em">{{ total | money }}</div>
            <button type="submit" class="btn btn-primary">Add Bundle to Cart</button>
          </div>
        </div>
      </form>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Frequently Bought Together",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Bought Together" }
  ],
  "presets": [{ "name": "Frequently Bought" }]
}
{% endschema %}
