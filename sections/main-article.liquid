<div class="container" style="padding:32px 24px;max-width:860px;">
  <nav class="breadcrumbs" style="margin-bottom:24px;">
    <a href="/">Home</a> &rsaquo; <a href="{{ blog.url }}">{{ blog.title }}</a> &rsaquo; <span>{{ article.title }}</span>
  </nav>

  <header class="article-header" style="margin-bottom:32px;">
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px;">
      {%- for tag in article.tags -%}
        <span style="background:rgba(0,166,81,0.1);color:#00A651;font-size:12px;padding:3px 10px;border-radius:20px;">{{ tag }}</span>
      {%- endfor -%}
    </div>
    <h1 style="color:#fff;font-size:36px;font-weight:700;line-height:1.3;margin-bottom:12px;">{{ article.title }}</h1>
    <div style="color:#8899aa;font-size:14px;display:flex;gap:16px;flex-wrap:wrap;">
      <span>By {{ article.author }}</span>
      <span>{{ article.published_at | date: "%B %d, %Y" }}</span>
    </div>
  </header>

  {%- if article.image -%}
    <div style="margin-bottom:32px;border-radius:12px;overflow:hidden;">
      {{ article.image | image_url: width: 1200 | image_tag: loading: "eager", style: "width:100%;display:block;" }}
    </div>
  {%- endif -%}

  <div class="article-content rte" style="color:#ccd6e0;line-height:1.8;font-size:16px;">
    {{ article.content }}
  </div>

  <div style="margin-top:40px;padding-top:24px;border-top:1px solid #1a2a40;display:flex;gap:12px;flex-wrap:wrap;align-items:center;">
    <span style="color:#8899aa;font-size:13px;">Share:</span>
    <button onclick="navigator.clipboard.writeText(window.location.href);this.textContent='Copied!';setTimeout(()=>this.textContent='Copy Link',2000)" class="btn btn-outline" style="font-size:13px;padding:6px 14px;">Copy Link</button>
    <a href="https://wa.me/?text={{ article.title | url_encode }}%20{{ shop.url }}{{ article.url | url_encode }}" target="_blank" rel="noopener" class="btn" style="background:#25D366;color:#fff;font-size:13px;padding:6px 14px;">WhatsApp</a>
  </div>

  <div style="margin-top:32px;">
    <a href="{{ blog.url }}" style="color:#00A651;text-decoration:none;font-size:14px;">← Back to {{ blog.title }}</a>
  </div>
</div>

{% schema %}
{"name":"Article","settings":[],"presets":[{"name":"Article"}]}
{% endschema %}
