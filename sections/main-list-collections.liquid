{{ 'collection.css' | asset_url | stylesheet_tag }}

<section class="page-hero">
  <div class="container">
    <h1>All Divisions</h1>
    <p>1,202+ medical devices across 20 specialties — sourced from world-class manufacturers, delivered same-day across Telangana.</p>
  </div>
</section>

<div class="container" style="padding:48px 24px">
  {%- comment -%} Group collections logically by handle prefix {%- endcomment -%}
  {%- assign surgical = 'trauma-fracture,arthroplasty,spine,sports-medicine,cardiovascular,endo-surgery' | split: ',' -%}
  {%- assign diagnostics = 'diagnostics,urology,gynecology,ent,ophthalmology,dental-cmf' | split: ',' -%}
  {%- assign consumables = 'consumables,wound-care,pain-management,aesthetic-plastic,power-tools,ot-equipment,sterilization,ppe-safety' | split: ',' -%}

  <div class="section-heading"><h2>Surgical Specialties</h2></div>
  <div class="grid grid-4" style="margin-bottom:64px">
    {%- for handle in surgical -%}
      {%- assign c = collections[handle] -%}
      {%- if c.id -%}{%- render 'collection-tile', collection: c -%}{%- endif -%}
    {%- endfor -%}
  </div>

  <div class="section-heading"><h2>Diagnostics &amp; Specialties</h2></div>
  <div class="grid grid-4" style="margin-bottom:64px">
    {%- for handle in diagnostics -%}
      {%- assign c = collections[handle] -%}
      {%- if c.id -%}{%- render 'collection-tile', collection: c -%}{%- endif -%}
    {%- endfor -%}
  </div>

  <div class="section-heading"><h2>Consumables &amp; Equipment</h2></div>
  <div class="grid grid-4">
    {%- for handle in consumables -%}
      {%- assign c = collections[handle] -%}
      {%- if c.id -%}{%- render 'collection-tile', collection: c -%}{%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} Any remaining collections not in the curated groups {%- endcomment -%}
  {%- assign all_handles = 'trauma-fracture,arthroplasty,spine,sports-medicine,cardiovascular,endo-surgery,diagnostics,urology,gynecology,ent,ophthalmology,dental-cmf,consumables,wound-care,pain-management,aesthetic-plastic,power-tools,ot-equipment,sterilization,ppe-safety' -%}
  {%- assign extras = '' -%}
  {%- for c in collections -%}
    {%- unless all_handles contains c.handle -%}
      {%- assign extras = extras | append: c.handle | append: ',' -%}
    {%- endunless -%}
  {%- endfor -%}
  {%- if extras != '' -%}
    <div class="section-heading" style="margin-top:64px"><h2>Other Collections</h2></div>
    <div class="grid grid-4">
      {%- for c in collections -%}
        {%- unless all_handles contains c.handle -%}
          {%- render 'collection-tile', collection: c -%}
        {%- endunless -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{%- comment -%} Inline tile snippet via capture (since we don't push it as a separate file) {%- endcomment -%}
<style>
  .collection-tile{
    background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
    padding:28px;display:flex;flex-direction:column;gap:8px;transition:all .3s;text-decoration:none;color:inherit;
  }
  .collection-tile:hover{transform:translateY(-4px);border-color:var(--green);box-shadow:var(--glow-green)}
  .collection-tile .icon{font-size:36px;line-height:1}
  .collection-tile h3{margin:8px 0 4px;font-size:18px}
  .collection-tile .desc{font-size:13px;color:var(--text-2);line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  .collection-tile .count{font-size:12px;color:var(--text-3);margin-top:auto;padding-top:12px;display:flex;justify-content:space-between;align-items:center}
  .collection-tile .count .go{color:var(--green);font-weight:600}
</style>

{% schema %}
{
  "name": "All Collections",
  "settings": []
}
{% endschema %}
