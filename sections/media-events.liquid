{%- assign news_blog = blogs[section.settings.blog] -%}
<section class="media-events section-pad">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{{ section.settings.heading | default: "News & Events" }}</h2>
    </div>
    <div class="articles-grid">
      {%- if news_blog != blank and news_blog.articles.size > 0 -%}
        {%- for article in news_blog.articles limit: 3 -%}
          <article class="article-card">
            {%- if article.image -%}
              <a href="{{ article.url }}" class="article-card-img" style="background-image:url('{{ article.image | image_url: width: 600 }}')"></a>
            {%- else -%}
              <a href="{{ article.url }}" class="article-card-img article-card-img--placeholder"></a>
            {%- endif -%}
            <div class="article-card-body">
              <time class="article-date">{{ article.published_at | date: "%b %d, %Y" }}</time>
              <h3 class="article-title"><a href="{{ article.url }}">{{ article.title }}</a></h3>
              <p class="article-excerpt">{{ article.excerpt | strip_html | truncate: 120 }}</p>
              <a href="{{ article.url }}" class="article-read-more">Read More →</a>
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <article class="article-card">
            <div class="article-card-img article-card-img--placeholder"></div>
            <div class="article-card-body">
              <time class="article-date">May 2025</time>
              <h3 class="article-title"><a href="#">Meril Life Sciences Launches Next-Gen Trauma Implants</a></h3>
              <p class="article-excerpt">Agile HealthCare brings the latest Meril innovations to all 33 Telangana districts with 2-hour delivery SLA.</p>
              <a href="#" class="article-read-more">Read More →</a>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>
<style>
.articles-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }
.article-card { background: #0a1628; border: 1px solid #1a2a40; border-radius: 10px; overflow: hidden; }
.article-card-img { display: block; aspect-ratio: 16/9; background-size: cover; background-position: center; background-color: #1a2a40; }
.article-card-img--placeholder { background-image: none; }
.article-card-body { padding: 20px; }
.article-date { color: #8899aa; font-size: 12px; }
.article-title { margin: 8px 0; }
.article-title a { color: #fff; text-decoration: none; font-size: 16px; font-weight: 600; line-height: 1.4; }
.article-title a:hover { color: #00A651; }
.article-excerpt { color: #8899aa; font-size: 14px; line-height: 1.6; margin-bottom: 16px; }
.article-read-more { color: #00A651; font-size: 13px; font-weight: 600; text-decoration: none; }
@media(max-width:768px){ .articles-grid { grid-template-columns: 1fr; } }
</style>

{% schema %}
{
  "name": "Media & Events",
  "settings": [
    {"type":"blog","id":"blog","label":"Blog"},
    {"type":"text","id":"heading","label":"Heading","default":"News & Events"}
  ],
  "presets": [{"name":"Media & Events"}]
}
{% endschema %}
